# GymBuddy Environment Variables

# Database Configuration
# For PostgreSQL (production)
DATABASE_URL=postgresql://username:password@localhost:5432/gymbuddy

# For SQLite (development) - leave empty to use default
# DATABASE_URL=

# Security
DJANGO_SECRET_KEY=your-secret-key-change-in-production
CSRF_TRUSTED_ORIGINS=http://localhost:3000,https://yourdomain.com

# CORS Configuration
CORS_ALLOW_ALL_ORIGINS=True  # Set to False in production
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Environment
ENVIRONMENT=development

# Optional: Cloudinary for image storage (uncomment to use)
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
